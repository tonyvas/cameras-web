<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/public/css/common.css">
    <link rel="stylesheet" href="/public/css/live/montage.css">
    <link rel="stylesheet" href="/public/css/live/streamer.css">

    <title>HLS Montage</title>
</head>
<body>
    <%- include('../partials/header', {active: '/live/montage'}) %>
    
    <main>
        <div id="controls">
            <div class="control-item">
                <input type="button" id="resize-button" value="Resize to Fit" onclick="resizeStreamersToFit();">
                <input type="button" id="reset-size-button" value="Reset Size" onclick="resetStreamersSize();">
            </div>
            <div class="control-item">
                <label for="col-range" id="col-range-label">Columns: N/A</label>
                <input type="range" id="col-range" min="1" max="5" step="1">
            </div>
        </div>

        <div id="streamers">
            <% for (let [name, path] of Object.entries(streamers)) { %>
                <div class="streamer">
                    <div class="streamer-header">
                        <span class="streamer-title"><%= name %></span>
                        <span class="streamer-bandwidth">N/A</span>
                    </div>
                    <div class="streamer-body">
                        <video class="streamer-video" data-src="/hls/<%= path %>/index.m3u8" muted controls></video>
                    </div>
                </div>
            <% } %> 
        </div>
    </main>

    <script src="/public/js/live/hls.js"></script>

    <script src="/public/js/live/main.js"></script>
    <script src="/public/js/live/hls-streamer.js"></script>
    <script src="/public/js/live/montage.js"></script>
</body>
</html>